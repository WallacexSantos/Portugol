programa
{
	
	funcao inicio()
	{
		/*Receba 1 valor, caso seja positivo, imprima na tela o
dobro do valor. Caso seja negativo imprima na tela o triplo
do número. Se o valor for zero apenas imprima a
mensagem “Nada a fazer, o número digitado foi 0”.*/
    real dobro,triplo,numero
    escreva ("digite um numero ")
    leia (numero)
    se (numero>0){
    	dobro=numero*2
    	escreva ("o dobro de ", numero, " e ", dobro)
    	}senao se (numero<0){
     triplo=numero*3
     escreva ("o triplo de ", numero ," e ", triplo)
     }senao se (numero==0){
     escreva ("nada a fazer, o numero digitado foi 0")
    	}
    	
    	
    }
}
