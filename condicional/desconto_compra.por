programa {
  funcao inicio() {
    real produtos,preco
    escreva ("digite a quantidade de produtos comprados ")
    leia (produtos)
    escreva ("digite o preco da compra ")
    leia (preco)
    se(produtos>50){
      escreva ("o preco da compra e ",preco*0.85 )
    }senao{ 
      escreva ("o preco da compra e ", preco)
    }
    }
  }

