programa {
  funcao inicio(){
    real numero, sim_ou_nao=1
    enquanto (sim_ou_nao==1){
    escreva ("digite um numero ")
    leia (numero)
    escreva ("o dobro do numero digitado e ",numero*2)
    escreva ("\ndeseja digitar mais um numero? (digite 1 para sim e 2 para nao) ")
    leia  (sim_ou_nao)
    }
  }
}
