programa
{
	
	funcao inicio()
	{
   inteiro idade
   escreva ("digite idade do membro do clube ")
   leia (idade)
   se (idade>21){
   escreva ("o membro e profissional")
   }senao se(idade<=20 e idade>16){
   	escreva ("o membro e junior")
   }
senao se (idade<=15 e idade>11){
   	escreva ("o membro e juvenil")
   }senao{
   	escreva ("o membro e infantil")
   }
}
}
