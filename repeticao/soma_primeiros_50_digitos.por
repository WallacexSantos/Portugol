programa {
  funcao inicio() {
    /*Faca um algoritmo que calcule e mostre a soma dos 50 primeiros números começando em 1 
(1+2+3+4+...+50).*/
    inteiro numero=0,total=0,soma=0
    faca{
    total++
    numero++
    soma = soma+numero
    se (numero==50)
    escreva("a soma dos primeiros 50 numeros e ",soma)}
    enquanto (total<50)
  }
}
